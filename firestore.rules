// ============================================================
// Firestore Security Rules — Immersive Experience Taxonomy
// ============================================================
//
// Paste these rules in: Firebase Console → Firestore Database
// → Rules → (replace everything) → Publish.
//
// ─────────────────────────────────────────────────────────────
// ADMINISTRATOR ALLOWLIST — the ONE place to manage edit access.
// To add or remove an administrator, edit this list and publish.
// UIDs come from: Firebase Console → Authentication → Users.
// ─────────────────────────────────────────────────────────────
//
// Access model:
//   Public (no account)  — read the published taxonomy
//   Any signed-in user   — manage ONLY their own profile and
//                          their own saved experiences
//   Administrators       — additionally write the taxonomy
//
// Creating an account NEVER grants admin access, and nothing a
// user can write (including their own profile document) is ever
// consulted for authorization — only this UID allowlist is.
// Users therefore cannot promote themselves.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin allowlist ─────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.uid in [
        "jtOD9eMDeETUXSALKFaQy0sCDiK2",   // Father
        "qN6weHvgweP171ka6dLtrOIU4203"    // Site maintainer
      ];
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // The published taxonomy (one document: taxonomy/current)
    match /taxonomy/{docId} {
      allow read: if true;              // public website
      allow write: if isAdmin();        // admins only
    }

    // User profiles: each user manages only their own document.
    // Profiles hold display metadata only — no roles, no passwords.
    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      // Saved experiences: private to their owner
      match /savedExperiences/{experienceId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    // Everything else: no access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
